#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
PROJECT_ROOT="$(realpath "$SCRIPT_DIR/..")"

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

show_usage() {
    cat <<'EOF'
Kuallpapers CLI Tool (mise-backed)
Usage: dev [task] [-- args]

Common commands:
  dev help
  dev install
  dev uninstall
  dev test
  dev package
  dev plasmoid
  dev release -- --draft
  dev release -- --prerelease
  dev clean

Native mise:
  mise run <task> [-- args]
  mise tasks ls
EOF
}

if ! command -v mise >/dev/null 2>&1; then
    log_warn "mise is not installed. Falling back to legacy dev-core script."
    exec "$SCRIPT_DIR/dev-core" "$@"
fi

if [ "$#" -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    show_usage
    exit 0
fi

if [ "${1:-}" = "help" ]; then
    mise tasks ls
    exit 0
fi

if [ ! -f "$PROJECT_ROOT/mise.toml" ]; then
    log_error "mise.toml not found in project root: $PROJECT_ROOT"
    exit 1
fi

exec mise run "$@"
